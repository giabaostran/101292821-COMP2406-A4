doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        title Login - Movie Weekend Planner
        link(rel="stylesheet", href="/styles/styles.css")
    body
        include header.pug

        main.container
            .centered
                h2 Sign In
                
                //- Display an error message if the server passes one back (e.g., invalid credentials)
                if error
                    p.error-message(style="color: red; font-weight: bold;")= error

                form#loginForm(action="/login", method="POST")
                    .form-row(style="justify-content: center; margin-bottom: 15px;")
                        label(for="username") Username:&nbsp;
                        input#username(type="text", name="username", required)
                    
                    .form-row(style="justify-content: center; margin-bottom: 15px;")
                        label(for="password") Password:&nbsp;
                        input#password(type="password", name="password", required)
                    
                    .form-row(style="justify-content: center; margin-top: 20px;")
                        button(type="submit") Sign in
                
                br
                p(style="text-align:center;") Don't have an account? 
                p(style="text-align:center;")
                  a(href="/register") Register or create an account